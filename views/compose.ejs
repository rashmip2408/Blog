<div class="container">
    <h1>Compose</h1>
    <form class="" action="/compose" method="post">
        <div class="form-group">
            <label class="font-weight-bold">Title</label>
            <input type="text" class="form-control" name="postTitle">
        </div>

        <div class="form-group">
            <label class="font-weight-bold">Post</label>
            <textarea class="form-control" name="postBody" rows="5" cols="30"></textarea>
        </div>
        <button type="submit" name="button" class="btn btn-primary">Publish</button>
    </form>
</div>


